# 개발 환경용 Dockerfile (Spring Boot DevTools + 바인딩 마운트)
FROM gradle:8.6-jdk21
WORKDIR /app

# Gradle 캐시를 위한 dependencies 설정
COPY build.gradle settings.gradle ./
COPY gradle ./gradle
RUN gradle dependencies --no-daemon || true

# 소스코드는 볼륨 마운트로 관리됨
# 개발 시 코드 변경사항이 즉시 반영됨

# Spring Boot DevTools를 활성화하여 자동 재시작
# bootRun을 사용하여 개발 모드로 실행
ENTRYPOINT ["gradle", "bootRun", "--no-daemon", "--args=--spring.profiles.active=dev"]

